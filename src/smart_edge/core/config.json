{
    "version": 1,
    "disable_existing_loggers": "False",
    "filters": {
        "require_debug_false": {
            "()": "logging.Filter",
            "name": "smartEdge"
        }
    },
    "formatters": {
        "standard": {
            "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
        },
        "simple": {
            "format": "%(levelname)s - %(message)s"
        },
        "json": {
            "()": "src.smart_edge.core.JSONFormatter.JSONFormatter",
            "fmt_keys": {
                "timestamp": "timestamp",
                "logger": "name",
                "level": "levelname",
                "thread": "threadName",
                "module": "module",
                "function": "funcName",
                "line": "lineno",
                "message": "message"
            }
        }
    },
    "handlers": {
        "stdout": {
            "class": "logging.StreamHandler",
            "formatter": "json",
            "stream": "ext://sys.stdout"
        },
        "file": {
            "class": "logging.handlers.RotatingFileHandler",
            "level": "DEBUG",
            "formatter": "json",
            "filename": "logs/smartEdge.log",
            "maxBytes": 10485760,
            "backupCount": 5
        }
    },
    "loggers": {
        "smartEdge": {
            "handlers": ["stdout", "file"],
            "level": "DEBUG",
            "propagate": "False"
        }
    }
}